  <filter>
  
  <filter-name>MyFilterOne</filter-name>
  <filter-class>com.MyFilterOne</filter-class>
  </filter>
  
  
  
  <filter-mapping>
  <filter-name>MyFilterOne</filter-name>
  <url-pattern>/AdminServlet</url-pattern>
  </filter-mapping>
  
  
  
  
